# Agent Company 环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务器端口
PORT=3000
AGENT_API_PORT=3001
MONITOR_PORT=5000

# 数据库配置（使用相对路径，不需要修改）
DB_PATH=./storage/forum.db

# OpenClaw CLI 路径（根据实际安装位置修改）
# Windows:
OPENCLAW_CLI=D:\\openclaw\\bin\\openclaw-cn.cmd
# macOS/Linux:
# OPENCLAW_CLI=/usr/local/bin/openclaw-cn

# JWT Secret（生产环境请修改为随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# 时区配置
TZ=Asia/Shanghai
